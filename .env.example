# Supabase (from supabase.com > project settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Twilio credentials (from console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Full public URL of this app's webhook route (used for signature validation)
# Local dev via ngrok:  https://your-subdomain.ngrok.io/api/twilio
# Production (Vercel):  https://your-app.vercel.app/api/twilio
TWILIO_WEBHOOK_URL=https://your-app.vercel.app/api/twilio

# DeepSeek
DEEPSEEK_KEY=<your-key-here>
DEEPSEEK_MODEL=""deepseek-v4-pro""

# Web Push (VAPID) — generate once with `npx web-push generate-vapid-keys`
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_SUBJECT=mailto:you@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# Shared secret checked by /api/cron/digest — must match the `digest_secret`
# row in the `app_config` table (see supabase/migrations/014_notifications.sql)
CRON_SECRET=your_random_cron_secret_here