# Supabase (from supabase.com > project settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Twilio credentials (from console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Full public URL of this app's webhook route (used for signature validation)
# Local dev via ngrok:  https://your-subdomain.ngrok.io/api/twilio
# Production (Vercel):  https://your-app.vercel.app/api/twilio
TWILIO_WEBHOOK_URL=https://your-app.vercel.app/api/twilio

# The Twilio phone number assigned to the hardcoded Phase 1 client (E.164 format)
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
